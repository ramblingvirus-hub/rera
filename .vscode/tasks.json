{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "RERA: Full QA Battery",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File ${workspaceFolder}/qa.ps1",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "RERA: Backend Tests",
      "type": "shell",
      "command": "${workspaceFolder}/venv/Scripts/python.exe -m pytest -q",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "RERA: Frontend Tests",
      "type": "shell",
      "command": "npm run test:run",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
