RERA_ENV=staging
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=staging.rera.example.com

# If using Railway Postgres, prefer DATABASE_URL and DB_SSLMODE over the separate DB_* values.
DATABASE_URL=
DB_SSLMODE=require

DB_NAME=rera_staging
DB_USER=rera_staging
DB_PASSWORD=replace-with-db-password
DB_HOST=127.0.0.1
DB_PORT=5432

PAYMONGO_PUBLIC_KEY=replace-if-used-in-staging
PAYMONGO_SECRET_KEY=replace-if-used-in-staging
PAYMONGO_ENABLED=true

# Manual payment instructions (shown in billing page)
GCASH_NUMBER=
GCASH_NAME=
GCASH_QR_URL=
MAYA_NUMBER=
MAYA_NAME=
MAYA_QR_URL=
ADMIN_EMAIL=

# If frontend and backend are on different domains, use the frontend origin here.
CORS_ALLOWED_ORIGINS=https://staging.rera.example.com
CSRF_TRUSTED_ORIGINS=https://staging.rera.example.com

USE_X_FORWARDED_HOST=true
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_HSTS_SECONDS=3600
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false